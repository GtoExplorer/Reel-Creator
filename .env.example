# OpenAI (used for scripting, voiceover and caption timing)
OPENAI_API_KEY=sk-...
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=onyx
OPENAI_TTS_SPEED=1.12
# Steers delivery/energy for gpt-4o-mini-tts (leave blank to use the built-in upbeat default)
OPENAI_TTS_INSTRUCTIONS=
OPENAI_TRANSCRIBE_MODEL=whisper-1

# GTOCentral SolverAPI (optional for the POC — falls back to mock data if unset)
SOLVER_API_BASE=https://api.gtocentral.com
SOLVER_API_TOKEN=

# Live Explorer capture (Playwright). Point at the running gto-central-next dev
# server. If unreachable, the flowchart scene falls back to the native chart.
EXPLORER_URL=http://localhost:3000/explorer
# Headless login: mint a session cookie using the webapp's SESSION_SECRET.
EXPLORER_SESSION_SECRET=
EXPLORER_LOGIN_EMAIL=

# --- Docker only -----------------------------------------------------------
# Which host:port the in-container socat forwards localhost:3000 to, to reach
# the webapp. Default = your host machine's dev server. Point elsewhere for a
# remote webapp (and set EXPLORER_URL accordingly).
WEBAPP_HOST=host.docker.internal
WEBAPP_PORT=3000

# Cloudflare Tunnel (only used by `docker compose --profile tunnel up`).
# Create a Named Tunnel in the Cloudflare dashboard, route your custom domain
# to service http://studio:4000, and paste the tunnel token here.
TUNNEL_TOKEN=
